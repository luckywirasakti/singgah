# ── singgah configuration ──
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real hosts, IPs or domains.

# ── Required ──
# Public domain that points at the proxy server (wildcard *.DOMAIN recommended).
DOMAIN=example.com

# ── CLI (singgah.sh) ──
# Server IP or hostname the SSH reverse tunnel connects to.
SINGGAH_SERVER=203.0.113.10
# SSH user on the server.
SINGGAH_USER=ubuntu
# Domain used by the CLI (defaults to DOMAIN if you mirror it here).
SINGGAH_DOMAIN=example.com
# Path to the names mapping file on the server.
SINGGAH_NAMES=/home/ubuntu/singgah/tunnel-names.json

# ── Proxy server (tunnel-proxy.cjs) ──
# Port the proxy listens on.
PROXY_PORT=3000
# Interface to bind to (0.0.0.0 = all).
BIND_HOST=0.0.0.0
# Directory with the built static site (SPA fallback).
STATIC_DIR=./dist
# Inclusive range of tunnel ports to scan and route.
# The number of friendly names is generated to match this range automatically.
TUNNEL_MIN=9000
TUNNEL_MAX=9015
# Port served for the apex/www domain.
DEFAULT_PORT=9000
# Optional: override the friendly-name pool (comma-separated, ordered).
# The Nth name maps to TUNNEL_MIN + N. Leave unset to use the built-in pool.
# TUNNEL_NAMES=panggung,dapur,loteng,gudang
# Where the generated name→port map is written (consumed by singgah-cli).
NAMES_FILE=./tunnel-names.json
# Loopback host where SSH terminates reverse tunnels.
TUNNEL_HOST=127.0.0.1
# Tuning (milliseconds).
SCAN_INTERVAL_MS=2000
SCAN_TIMEOUT_MS=500
PROXY_TIMEOUT_MS=30000
