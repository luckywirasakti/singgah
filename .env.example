# ── singgah configuration ──
# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored — never commit real hosts, IPs or domains.

# ── Required ──
# Public domain that points at the proxy server (wildcard *.DOMAIN recommended).
DOMAIN=example.com

# ── CLI (cli/singgah.sh) ──
# Server IP or hostname the SSH reverse tunnel connects to.
SINGGAH_SERVER=203.0.113.10
# SSH user on the server.
SINGGAH_USER=ubuntu
# Domain used by the CLI (mirror DOMAIN).
SINGGAH_DOMAIN=example.com
# Base tunnel port — MUST match the proxy's PORT_BASE below.
SINGGAH_BASE=9000
# Shared secret enabling DYNAMIC subdomain names. The CLI registers a fresh
# random name per tunnel with the proxy's control plane. MUST be identical on
# both sides (CLI and proxy). Leave empty to keep the original static names.
# Generate one with:  openssl rand -hex 24
SINGGAH_SECRET=

# ── Proxy server (server/proxy.ts) ──
# Port the proxy listens on.
PROXY_PORT=3000
# Interface to bind to (0.0.0.0 = all).
BIND_HOST=0.0.0.0
# Directory with the built static site (SPA fallback).
STATIC_DIR=./dist
# Base of the addressable tunnel window. The top is derived automatically from
# the name pool size (no max to configure). Subdomains map only to ports in
# [PORT_BASE, PORT_BASE + pool size) — this also acts as a security allowlist.
PORT_BASE=9000
# Port served for the apex/www domain (defaults to PORT_BASE).
DEFAULT_PORT=9000
# Loopback host where SSH terminates reverse tunnels.
TUNNEL_HOST=127.0.0.1
# Upstream request timeout (milliseconds).
PROXY_TIMEOUT_MS=30000
# Shared secret for the dynamic-name control plane. MUST match the CLI's
# SINGGAH_SECRET. Empty = dynamic names disabled (static matrix only).
SINGGAH_SECRET=
# Where the proxy persists the dynamic name→port registry (survives restart).
REGISTRY_FILE=./singgah-registry.json
# How long a registered name lives without renewal (ms). The CLI releases names
# on exit, so this is just a safety net for crashed clients (default: 24h).
REGISTRY_TTL_MS=86400000
